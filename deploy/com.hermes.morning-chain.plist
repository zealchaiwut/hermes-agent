<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd StartCalendarInterval fires at SYSTEM LOCAL TIME (not UTC).
  On a Bangkok-TZ host (Asia/Bangkok, UTC+7) this fires at 05:45 ICT each morning.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hermes.morning-chain</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>HERMES_REPO/deploy/bin/morning-chain.sh</string>
  </array>

  <!--
    Fire at 05:45 local time daily (Asia/Bangkok, UTC+7).
    StartCalendarInterval uses system local time — not UTC.
    Ensure the Mac is already awake before this fires; see deploy/README.md
    for the recommended pmset wakeorpoweron command.
  -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>5</integer>
    <key>Minute</key>
    <integer>45</integer>
  </dict>

  <key>EnvironmentVariables</key>
  <dict>
    <!--
      Non-interactive Claude auth: export your OAuth token here.
      See deploy/README.md for details on obtaining this token.
    -->
    <key>CLAUDE_CODE_OAUTH_TOKEN</key>
    <string>REPLACE_WITH_YOUR_TOKEN</string>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>HERMES_REPO/logs/morning-chain-launchd.log</string>
  <key>StandardErrorPath</key>
  <string>HERMES_REPO/logs/morning-chain-launchd.log</string>

  <key>WorkingDirectory</key>
  <string>HERMES_REPO</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
